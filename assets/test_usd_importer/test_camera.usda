#usda 1.0
(
    metersPerUnit = 0.01
    upAxis = "Z"
)

def Xform "CameraActor"
{
    double3 xformOp:translate = (100, 200, 300)
    uniform token[] xformOpOrder = ["xformOp:translate"]

    def Camera "CameraComponent"
    {
        float2 clippingRange = (10, 100000)
        float focalLength = 100
        float focusDistance = 250
        float fStop = 2.8
        float horizontalAperture = 36
        float verticalAperture = 19
        token projection = "perspective"
        float3 xformOp:rotateXYZ = (10, 20, 30)
        double3 xformOp:translate = (4, 5, 6)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
    }
}

def Xform "FallbackActor"
{
    def Camera "HorizontalFallbackCamera"
    {
        float focalLength = 50
        float horizontalAperture = 32
    }
}
